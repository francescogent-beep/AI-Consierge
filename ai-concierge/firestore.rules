rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: chats
    // Document ID: {chatId}
    // Fields:
    //   - id: string (required) - Unique ID
    //   - userId: string (required) - Owner UID
    //   - title: string (required, max 100 chars) - Chat title
    //   - provider: string (required) - AI Provider name
    //   - lastMessage: string (optional, max 500 chars) - Last message preview
    //   - timestamp: timestamp (required) - Creation/Update time
    //   - isBookmarked: bool (optional) - Bookmark status
    //
    // Collection: chats/{chatId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - id: string (required)
    //   - chatId: string (required)
    //   - role: string (required, enum: user|assistant)
    //   - content: string (required, max 5000 chars)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isChatOwner(chatId) {
      return isOwner(get(/databases/$(database)/documents/chats/$(chatId)).data.userId);
    }

    function isValidChat(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'provider', 'timestamp']) &&
             data.id is string &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 100 &&
             data.provider in ['ChatGPT', 'Claude', 'Gemini', 'Perplexity'] &&
             data.timestamp is timestamp &&
             (!('lastMessage' in data) || (data.lastMessage is string && data.lastMessage.size() <= 500)) &&
             (!('isBookmarked' in data) || data.isBookmarked is bool);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'chatId', 'role', 'content', 'timestamp']) &&
             data.id is string &&
             data.chatId is string &&
             data.role in ['user', 'assistant'] &&
             data.content is string && data.content.size() <= 5000 &&
             data.timestamp is timestamp;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "francesco_gent@yahoo.it" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /chats/{chatId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidChat(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isValidChat(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);

      match /messages/{messageId} {
        allow read: if isChatOwner(chatId);
        allow create: if isChatOwner(chatId) && isValidMessage(request.resource.data);
        allow update, delete: if false; // Messages are immutable for now
      }
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && 
                              request.resource.data.keys().hasOnly(['role', 'email', 'name']) &&
                              request.resource.data.role == 'user'; // Users can't make themselves admin
      allow delete: if isAdmin();
    }
  }
}
