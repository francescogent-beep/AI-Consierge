{
  "entities": {
    "Chat": {
      "title": "Chat",
      "description": "A conversation between the user and an AI provider",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the chat" },
        "userId": { "type": "string", "description": "UID of the owner" },
        "title": { "type": "string", "description": "Display title of the chat" },
        "provider": { "type": "string", "enum": ["ChatGPT", "Claude", "Gemini", "Perplexity"] },
        "lastMessage": { "type": "string", "description": "Preview of the last message" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isBookmarked": { "type": "boolean" }
      },
      "required": ["id", "userId", "title", "provider", "timestamp"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "chatId", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Top-level collection for user chats"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Subcollection for messages within a specific chat"
    }
  }
}
